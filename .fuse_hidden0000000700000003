<main>
  <section class="page-hero">
    <div class="container">
      <p class="breadcrumb"><a href="index.html">Inicio</a> / Contacto</p>
      <h1>Hablemos directamente</h1>
      <p class="lead">Sin redes sociales ni gestores intermedios: escribe, llama o envía un WhatsApp y te responderé personalmente.</p>
    </div>
  </section>

  <section>
    <div class="container contact-grid">
      <div class="contact-info">
        <h2>Datos de contacto</h2>

        <div class="info-item">
          <div class="ic">✉</div>
          <div>
            <h4>Email</h4>
            <p><a href="mailto:info@consultoriaagricolaintegral.es">info@consultoriaagricolaintegral.es</a></p>
          </div>
        </div>

        <div class="info-item">
          <div class="ic">☎</div>
          <div>
            <h4>Teléfono</h4>
            <p><a href="tel:+34692032785">692 03 27 85</a></p>
          </div>
        </div>

        <div class="info-item">
          <div class="ic">💬</div>
          <div>
            <h4>WhatsApp</h4>
            <p><a href="https://wa.me/34692032785" id="wa-link">Enviar WhatsApp</a></p>
          </div>
        </div>

        <div class="info-item">
          <div class="ic">📍</div>
          <div>
            <h4>Zona de servicio</h4>
            <p>Comunitat Valenciana: provincias de Valencia, Castellón y Alicante</p>
          </div>
        </div>

        <div class="info-item">
          <div class="ic">🕐</div>
          <div>
            <h4>Horario de atención</h4>
            <p>Lunes a viernes, de 9:00 a 14:00 y de 16:00 a 19:00</p>
          </div>
        </div>
      </div>

      <div class="contact-form">
        <h2>Formulario de contacto</h2>
        <p style="font-size:0.9rem; margin-bottom:20px;">Al enviar este formulario, tu mensaje llega directamente a nuestro correo. No se comparte con terceros ni se usa para publicidad.</p>

        <!--
          NOTA TÉCNICA para quien administre la web:
          Este formulario usa FormSubmit (https://formsubmit.co), un servicio gratuito
          que reenvía el contenido del formulario directamente al email indicado en
          "action", sin necesidad de servidor propio ni redes sociales.
          La primera vez que alguien envíe el formulario, FormSubmit pedirá confirmar
          la dirección info@consultoriaagricolaintegral.es por correo (solo una vez).
          Alternativa equivalente: Netlify Forms si la web se aloja en Netlify.
        -->
        <form action="https://formsubmit.co/info@consultoriaagricolaintegral.es" method="POST">
          <input type="hidden" name="_subject" value="Nueva consulta desde la web Consultoría Agrícola Integral">
          <input type="hidden" name="_template" value="table">
          <input type="hidden" name="_captcha" value="true">

          <div class="form-row">
            <div class="field">
              <label for="nombre">Nombre y apellidos *</label>
              <input type="text" id="nombre" name="Nombre" required>
            </div>
            <div class="field">
              <label for="telefono">Teléfono *</label>
              <input type="tel" id="telefono" name="Teléfono" required>
            </div>
          </div>

          <div class="form-row">
            <div class="field">
              <label for="email">Email *</label>
              <input type="email" id="email" name="Email" required>
            </div>
            <div class="field">
              <label for="servicio">Servicio de interés</label>
              <select id="servicio" name="Servicio">
                <option value="Trámites y gestión de parcelas">Trámites y gestión de parcelas</option>
                <option value="Asesoramiento agronómico">Asesoramiento agronómico</option>
                <option value="Construcción rural">Construcción rural</option>
                <option value="Eficiencia energética e hídrica">Eficiencia energética e hídrica</option>
                <option value="No lo tengo claro / consulta general">No lo tengo claro / consulta general</option>
              </select>
            </div>
          </div>

          <div class="field" style="margin-bottom:18px;">
            <label for="municipio">Municipio de la parcela o explotación</label>
            <input type="text" id="municipio" name="Municipio" placeholder="Ej. Xàtiva, Sagunto, Requena...">
          </div>

          <div class="field" style="margin-bottom:18px;">
            <label for="mensaje">Cuéntame tu caso *</label>
            <textarea id="mensaje" name="Mensaje" rows="5" required placeholder="Describe brevemente tu parcela, explotación o el problema al que te enfrentas..."></textarea>
          </div>

          <div class="consent">
            <input type="checkbox" id="consentimiento" required>
            <label for="consentimiento">Acepto que estos datos se usen únicamente para responder a mi consulta, conforme al RGPD. No se cederán a terceros ni se usarán con fines publicitarios.</label>
          </div>

          <button type="submit" class="btn btn-primary">Enviar consulta</button>
        </form>
      </div>
    </div>
